{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gyre Helm Chart Values",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "hostNetwork": { "type": "boolean" },
    "hostPID": { "type": "boolean" },
    "hostIPC": { "type": "boolean" },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "tag": { "type": "string" }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": { "type": "object" }
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "origin": {
      "anyOf": [
        { "const": "" },
        {
          "type": "string",
          "pattern": "^https?://.+"
        }
      ]
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "automount": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "podAnnotations": { "type": "object" },
    "podLabels": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": { "type": "integer" },
        "targetPort": { "type": "integer" },
        "nodePort": { "type": "integer" }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "host": { "type": "string" },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "path": { "type": "string" },
                    "pathType": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "tls": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "gatewayApi": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "annotations": { "type": "object" },
        "parentRefs": {
          "type": "array",
          "items": { "type": "object" }
        },
        "hostnames": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tls": { "type": "boolean" },
        "rules": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" },
            "ephemeral-storage": { "type": "string" }
          }
        },
        "requests": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" },
            "ephemeral-storage": { "type": "string" }
          }
        }
      }
    },
    "livenessProbe": { "type": "object" },
    "readinessProbe": { "type": "object" },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "storageClass": { "type": "string" },
        "accessMode": { "type": "string" },
        "size": { "type": "string" },
        "annotations": { "type": "object" },
        "existingClaim": { "type": "string" }
      }
    },
    "nodeSelector": { "type": "object" },
    "tolerations": {
      "type": "array",
      "items": { "type": "object" }
    },
    "affinity": { "type": "object" },
    "rbac": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "clusterRole": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "create": { "type": "boolean" },
            "readOnly": { "type": "boolean" },
            "rules": {
              "type": "array",
              "items": { "type": "object" }
            }
          }
        }
      }
    },
    "admin": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "autoGenerate": { "type": "boolean" },
        "secretName": { "type": "string" }
      }
    },
    "encryption": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gyreKey": { "type": "string" },
        "authKey": { "type": "string" },
        "existingSecret": { "type": "string" },
        "allowInline": { "type": "boolean" }
      },
      "if": {
        "properties": { "allowInline": { "const": true } },
        "required": ["allowInline"]
      },
      "then": {
        "properties": {
          "gyreKey": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
          "authKey": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" }
        },
        "required": ["gyreKey", "authKey"]
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "localLoginEnabled": { "type": "boolean" },
        "allowSignup": { "type": "boolean" },
        "domainAllowlist": {
          "type": "array",
          "items": { "type": "string" }
        },
        "providers": {
          "type": "array",
          "items": { "type": "object" }
        },
        "providersExistingSecret": { "type": "string" }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "interval": { "type": "string" },
            "path": { "type": "string" },
            "additionalLabels": { "type": "object" }
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "dnsNamespace": { "type": "string" },
        "apiServerNamespace": { "type": "string" },
        "ingress": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "podSelector": { "type": "object" },
            "namespaceSelector": { "type": "object" },
            "additionalRules": {
              "type": "array",
              "items": { "type": "object" }
            }
          }
        },
        "egress": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "apiServer": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "namespaceSelector": { "type": "object" },
                "podSelector": { "type": "object" },
                "ipBlocks": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "ports": {
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 65535
                  }
                }
              }
            },
            "additionalRules": {
              "type": "array",
              "items": { "type": "object" }
            }
          }
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "pollIntervalMs": {
          "type": "integer",
          "minimum": 1000
        },
        "heartbeatIntervalMs": {
          "type": "integer",
          "minimum": 1000
        },
        "dashboardCacheTtlMs": {
          "type": "integer",
          "minimum": 1000
        },
        "settlingPeriodMs": {
          "type": "integer",
          "minimum": 1000
        },
        "additionalConfig": { "type": "object" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string" }
          ]
        },
        "maxUnavailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string" }
          ]
        }
      }
    }
  }
}
