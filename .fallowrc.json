{
	"$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
	"entry": [
		"src/hooks.{ts,js}",
		"src/hooks.{client,server}.{ts,js}",
		"src/service-worker.{ts,js}",
		"src/routes/**/+*.{svelte,ts,js}"
	],
	"workspaces": {
		"patterns": [".", "documentation"]
	},
	"duplicates": {
		"minOccurrences": 3
	},
	"ignoreDependencies": ["@mdx-js/react", "@docusaurus/module-type-aliases"],
	"ignoreExports": [
		{
			"file": "src/lib/components/ui/**/index.ts",
			"exports": ["*"]
		},
		{
			"file": "src/lib/server/db/index.ts",
			"exports": ["*"]
		},
		{
			"file": "src/lib/server/db/schema.ts",
			"exports": ["*"]
		},
		{
			"file": "src/lib/server/db/schemas/*.ts",
			"exports": ["*"]
		},
		{
			"file": "src/lib/types/*.ts",
			"exports": ["*"]
		},
		{
			"file": "src/routes/**/+server.ts",
			"exports": ["_metadata"]
		},
		{
			"file": "src/lib/server/auth/crypto.ts",
			"exports": ["*"]
		},
		{
			"file": "src/lib/server/clusters/encryption.ts",
			"exports": ["*"]
		},
		{
			"file": "src/lib/templates/index.ts",
			"exports": [
				"GIT_REPOSITORY_TEMPLATE",
				"HELM_REPOSITORY_TEMPLATE",
				"KUSTOMIZATION_TEMPLATE",
				"HELM_RELEASE_TEMPLATE",
				"HELM_CHART_TEMPLATE",
				"BUCKET_TEMPLATE",
				"OCI_REPOSITORY_TEMPLATE",
				"ALERT_TEMPLATE",
				"PROVIDER_TEMPLATE",
				"RECEIVER_TEMPLATE",
				"IMAGE_REPOSITORY_TEMPLATE",
				"IMAGE_POLICY_TEMPLATE",
				"IMAGE_UPDATE_AUTOMATION_TEMPLATE"
			]
		},
		{
			"file": "src/lib/server/auth/oauth/index.ts",
			"exports": [
				"IOAuthProvider",
				"OAuthUserInfo",
				"OIDCDiscovery",
				"OAuthProviderOptions",
				"ProviderType",
				"OIDCProvider",
				"GitHubProvider",
				"GitLabProvider",
				"GoogleProvider",
				"createOAuthProvider",
				"getAuthProviderById"
			]
		}
	],
	"usedClassMembers": [
		{
			"implements": "IOAuthProvider",
			"members": ["getAuthorizationUrl", "validateCallback", "getUserInfo", "refreshAccessToken"]
		}
	]
}
