# Required in production. 64-character hexadecimal string (32 bytes).
# Generate with: openssl rand -hex 32
GYRE_ENCRYPTION_KEY=

# Required in production. 64-character hexadecimal string (32 bytes).
# Generate with: openssl rand -hex 32
AUTH_ENCRYPTION_KEY=

# Required. Used by Better Auth to construct OAuth callback and redirect URLs.
# In production, set to your public-facing URL (e.g. https://gyre.example.com).
BETTER_AUTH_URL=http://localhost:5173

# Optional. If unset, Better Auth falls back to AUTH_ENCRYPTION_KEY.
# Set this separately when rotating auth/session secrets independently from encrypted OAuth secrets.
# BETTER_AUTH_SECRET=

# Optional. When set, backups are AES-256-GCM encrypted before being written to disk.
# If unset, backups are stored as plain .db files with a warning logged.
# Generate with: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=
# Optional: Default admin password for FIRST-TIME setup.
# Works in both local and Kubernetes environments for initial account creation.
# In production, it's recommended to let Gyre generate a secure secret instead.
# ADMIN_PASSWORD=admin-password

NODE_ENV=development

# ---------------------------------------------------------------------------
# Tunable constants (all optional — defaults shown)
# ---------------------------------------------------------------------------

# Maximum number of local backup files to retain before the oldest is pruned.
# GYRE_MAX_LOCAL_BACKUPS=10

# TTL for the in-memory settings cache (milliseconds).
# GYRE_SETTINGS_CACHE_TTL_MS=30000

# TTL for the dashboard resource-count cache (milliseconds).
# GYRE_DASHBOARD_CACHE_TTL_MS=30000

# Settling period after an ADDED event before notifications are emitted (ms).
# Prevents spam during initial cluster sync.
# GYRE_SETTLING_PERIOD_MS=30000

# Interval between Kubernetes API polls (milliseconds).
# GYRE_POLL_INTERVAL_MS=5000

# Interval between SSE heartbeat messages sent to connected clients (milliseconds).
# GYRE_HEARTBEAT_INTERVAL_MS=30000

# Maximum request body size accepted by adapter-node (default: 512K).
# Must be set to ≥ 500M to allow kubeconfig and backup uploads.
# Per-endpoint limits are enforced in src/hooks.server.ts via Content-Length.
# BODY_SIZE_LIMIT=500M
